# .env.example — SherLock Part 1: Data & Intelligence Backend
# Copy to .env and fill values. Never commit .env.

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_REASONING_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_REASONING_TEMPERATURE=0.1
OPENAI_NARRATIVE_TEMPERATURE=0.7
OPENAI_MAX_TOKENS_REASONING=3000
OPENAI_MAX_TOKENS_NARRATIVE=1500

# ─── Neo4j ────────────────────────────────────────────────────────────────────
NEO4J_URI=neo4j+s://<aura-instance-id>.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=...
NEO4J_DATABASE=neo4j
NEO4J_MAX_CONNECTION_POOL_SIZE=50
NEO4J_CONNECTION_TIMEOUT_SECONDS=10

# ─── Tavily ───────────────────────────────────────────────────────────────────
TAVILY_API_KEY=tvly-...
TAVILY_MAX_RESULTS=5
TAVILY_MAX_CALLS_PER_INVESTIGATION=3
TAVILY_SEARCH_DEPTH=advanced
TAVILY_DAYS_FRESH=30

# ─── Kafka (AWS MSK) ──────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_TELEMETRY_METRICS=telemetry.metrics
KAFKA_TOPIC_TELEMETRY_LOGS=telemetry.logs
KAFKA_TOPIC_TELEMETRY_TRACES=telemetry.traces
KAFKA_TOPIC_TELEMETRY_EVENTS=telemetry.events
KAFKA_TOPIC_INVESTIGATIONS_COMPLETED=sre.investigations.completed
KAFKA_CONSUMER_GROUP_GRAPH_WRITER=graph-writer-group
KAFKA_CONSUMER_GROUP_AGENT=sre-agent-group

# ─── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_S3_INVESTIGATIONS_BUCKET=sre-investigations
AWS_S3_STAGING_BUCKET=sre-telemetry-staging
AWS_SQS_INVESTIGATIONS_COMPLETED_URL=
AWS_SECRETS_MANAGER_SECRET_NAME=sre-platform/part1/secrets

# ─── Agent Configuration ──────────────────────────────────────────────────────
AGENT_MAX_INVESTIGATION_MINUTES=6
AGENT_DEDUP_WINDOW_MINUTES=5
AGENT_CONFIDENCE_AUTONOMOUS_THRESHOLD=0.85
AGENT_CONFIDENCE_MEDIUM_THRESHOLD=0.60
AGENT_MAX_HYPOTHESES=5
AGENT_MAX_EVIDENCE_QUERIES_PER_HYPOTHESIS=3
AGENT_VECTOR_SEARCH_TOP_K=5

# ─── LLM Fallback (Amazon Bedrock) ───────────────────────────────────────────
BEDROCK_FALLBACK_ENABLED=false
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_REGION=us-east-1

# ─── Local Dev ───────────────────────────────────────────────────────────────
ENV=local

# ─── Observability ───────────────────────────────────────────────────────────
LOG_LEVEL=INFO
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=sre-agent
